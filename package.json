{
  "name": "@movoice/mcp",
  "version": "1.0.0",
  "description": "MCP server for Movoice AI — create and manage voice AI agents directly from Claude or Cursor",
  "type": "module",
  "bin": {
    "movoice-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "voice-ai",
    "ai-agents",
    "movoice",
    "telephony",
    "voice-agents"
  ],
  "author": "Movoice AI <hello@movoice.ai>",
  "license": "MIT",
  "homepage": "https://github.com/Movoiceai/movoice-mcp#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Movoiceai/movoice-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Movoiceai/movoice-mcp/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
